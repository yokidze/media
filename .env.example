NODE_ENV=development

# External PostgreSQL (recommended: managed cloud DB)
DATABASE_URL=postgresql://archive_user:CHANGE_ME_STRONG_DB_PASSWORD@db.example.com:5432/polytech_media_archive?schema=public
# Optional direct URL for Prisma CLI/migrations when using pooled URLs
DIRECT_DATABASE_URL=postgresql://archive_user:CHANGE_ME_STRONG_DB_PASSWORD@db.example.com:5432/polytech_media_archive?schema=public

# Optional local postgres values (used only if you run docker profile local-db)
POSTGRES_DB=polytech_media_archive
POSTGRES_USER=archive_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# API
HOST=0.0.0.0
PORT=4000
API_BASE_PATH=/api/v1
APP_ORIGIN=http://localhost
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_ACCESS_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_REFRESH_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
CSRF_COOKIE_NAME=college_csrf
ACCESS_TOKEN_COOKIE_NAME=college_access
REFRESH_TOKEN_COOKIE_NAME=college_refresh
FILE_MAX_SIZE_MB=100
STORAGE_DRIVER=LOCAL
STORAGE_LOCAL_ROOT=../../storage

# Optional seed-only initial passwords. Leave empty to generate temporary passwords.
SEED_ADMIN_EMAIL=polytech@admin.com
SEED_ADMIN_PASSWORD=adminpolytech
SEED_STAFF_PASSWORD=

# S3 / MinIO (optional)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=polytech-media-archive
S3_ACCESS_KEY_ID=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET_KEY
S3_FORCE_PATH_STYLE=true

# Frontend
NEXT_PUBLIC_SITE_URL=http://localhost
NEXT_PUBLIC_CLIENT_API_BASE=/api/v1
NEXT_PUBLIC_API_PROXY_TARGET=http://localhost:4000
INTERNAL_API_BASE=http://localhost:4000/api/v1
NEXT_PUBLIC_CSRF_COOKIE_NAME=college_csrf
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_NAME=college_access
NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_NAME=college_refresh
