NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_BASE_PATH=/api/v1
APP_ORIGIN=http://localhost

# External PostgreSQL (recommended)
DATABASE_URL=postgresql://archive_user:change_me@db.example.com:5432/polytech_media_archive?schema=public
# Optional direct URL for Prisma CLI/migrations when using pooled URLs
DIRECT_DATABASE_URL=postgresql://archive_user:change_me@db.example.com:5432/polytech_media_archive?schema=public

JWT_ACCESS_SECRET=change_me_to_a_very_long_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_a_very_long_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
CSRF_COOKIE_NAME=college_csrf
ACCESS_TOKEN_COOKIE_NAME=college_access
REFRESH_TOKEN_COOKIE_NAME=college_refresh
STORAGE_DRIVER=LOCAL
STORAGE_LOCAL_ROOT=../../storage
FILE_MAX_SIZE_MB=100

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=polytech-media-archive
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=miniosecret
S3_FORCE_PATH_STYLE=true
